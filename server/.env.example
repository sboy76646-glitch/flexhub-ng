MONGO_URI=mongodb://127.0.0.1:27017/flexhub-ng
JWT_SECRET=replace-with-a-long-random-secret
PORT=5000
CLIENT_URL=http://localhost:5173

# Paystack payments (use test keys during review)
PAYSTACK_SECRET_KEY=

# Marketplace rules
DELIVERY_FEE_NAIRA=0
PAYOUT_HOLD_DAYS=7

# Safety switches: leave both off until payout testing and approval are complete.
ENABLE_PAYSTACK_TRANSFERS=false
ENABLE_AUTOMATED_PAYOUTS=false
